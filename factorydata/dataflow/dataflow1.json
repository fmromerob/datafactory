{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Ventas",
						"type": "DatasetReference"
					},
					"name": "ventas"
				},
				{
					"dataset": {
						"referenceName": "productos",
						"type": "DatasetReference"
					},
					"name": "productos"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "Json1",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "joinventasproductos"
				},
				{
					"name": "addtotalincome"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ID_Transaccion as string,",
				"          Fecha as string,",
				"          Producto_SKU as string,",
				"          Cantidad as string,",
				"          Precio_Unitario as string,",
				"          ID_Tienda as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> ventas",
				"source(output(",
				"          SKU as string,",
				"          Nombre_Producto as string,",
				"          Categoria as string,",
				"          Costo_Base as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> productos",
				"ventas, productos join(Producto_SKU == SKU,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinventasproductos",
				"joinventasproductos derive(ingreso_total = multiply(toDouble(Cantidad), toDouble(Precio_Unitario))) ~> addtotalincome",
				"addtotalincome sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}