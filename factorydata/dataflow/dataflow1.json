{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Ventas",
						"type": "DatasetReference"
					},
					"name": "ventas"
				},
				{
					"dataset": {
						"referenceName": "productos",
						"type": "DatasetReference"
					},
					"name": "productos"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "join1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ID_Transaccion as string,",
				"          Fecha as string,",
				"          Producto_SKU as string,",
				"          Cantidad as string,",
				"          Precio_Unitario as string,",
				"          ID_Tienda as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> ventas",
				"source(output(",
				"          SKU as string,",
				"          Nombre_Producto as string,",
				"          Categoria as string,",
				"          Costo_Base as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> productos",
				"ventas, productos join(ERROR_FUNCTION('') == ERROR_FUNCTION(''),",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1"
			]
		}
	}
}